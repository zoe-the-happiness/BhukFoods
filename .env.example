# Bhuk Foods — local environment template
# Copy to .env.local and fill in real values for local dev.
# Production values live in Vercel env vars — never commit secrets to this file.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://atbjnresahzomvmqrlef.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@bhukfoods.com

# Operator accounts (used by seed and cron)
ADMIN_EMAIL=
COOK_EMAIL=
EPSON_PRINTER_EMAIL=

# Web Push (VAPID) — generate with `npm run vapid:gen`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@bhukfoods.com

# Public site config
NEXT_PUBLIC_SITE_URL=https://www.bhukfoods.com
NEXT_PUBLIC_CLARITY_ID=

# Cron auth (used by Vercel cron / pg_cron HTTP calls)
CRON_SECRET=
